@article{streit_harness_2023,
	title = {To harness traits for ecology, let’s abandon ‘functionality’},
	volume = {38},
	issn = {0169-5347},
	url = {https://www.sciencedirect.com/science/article/pii/S0169534722002890},
	doi = {10.1016/j.tree.2022.11.009},
	abstract = {Traits are measurable features of organisms. Functional traits aspire to more. They quantify an organism’s ecology and, ultimately, predict ecosystem functions based on local communities. Such predictions are useful, but only if ‘functional’ really means ‘ecologically relevant’. Unfortunately, many ‘functional’ traits seem to be characterized primarily by availability and implied importance – not by their ecological information content. Better traits are needed, but a prevailing trend is to ‘functionalize’ existing traits. The key may be to invert the process, that is, to identify functions of interest first and then identify traits as quantifiable proxies. We propose two distinct, yet complementary, perspectives on traits and provide a ‘taxonomy of traits’, a conceptual compass to navigate the diverse applications of traits in ecology.},
	language = {en},
	number = {5},
	urldate = {2023-04-17},
	journal = {Trends in Ecology \& Evolution},
	author = {Streit, Robert P. and Bellwood, David R.},
	month = may,
	year = {2023},
	keywords = {ecosystem function, functional trait, global change, resilience, trait ecology, /unread},
	pages = {402--411},
	file = {ScienceDirect Snapshot:/Users/leitejard/Zotero/storage/2ETQSW4K/S0169534722002890.html:text/html;Streit_Bellwood_2023_To harness traits for ecology, let’s abandon ‘functionality’.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Streit_Bellwood_2023_To harness traits for ecology, let’s abandon ‘functionality’.pdf:application/pdf},
