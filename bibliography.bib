	editor = {Mienert, Jürgen and Weaver, Philip},
	year = {2003},
	keywords = {/unread, Global Position System, Internal Tide, Sand Bank, Turbidite System, Zone Economique Exclusive},
	pages = {223--228},
	file = {Auffret et al. - 2003 - The Celtic and Armorican Margins — a New View.pdf:/Users/leitejard/Zotero/storage/7S9RG328/Auffret et al. - 2003 - The Celtic and Armorican Margins — a New View.pdf:application/pdf},
