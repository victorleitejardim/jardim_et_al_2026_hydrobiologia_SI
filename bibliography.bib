@article{keddy_assembly_1992,
	title = {Assembly and response rules: two goals for predictive community ecology},
	volume = {3},
	copyright = {1992 IAVS - the International Association of Vegetation Science},
	issn = {1654-1103},
	shorttitle = {Assembly and response rules},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.2307/3235676},
	doi = {10.2307/3235676},
	abstract = {Abstract. Assembly rules provide one possible unifying framework for community ecology. Given a species pool, and measured traits for each species, the objective is to specify which traits (and therefore which subset of species) will occur in a particular environment. Because the problem primarily involves traits and environments, answers should be generalizable to systems with very different taxonomic composition. In this context, the environment functions like a filter (or sieve) removing all species lacking specified combinations of traits. In this way, assembly rules are a community level analogue of natural selection. Response rules follow a similar process except that they transform a vector of species abundances to a new vector using the same information. Examples already exist from a range of habitats, scales, and kinds of organisms.},
	language = {en},
	number = {2},
	urldate = {2024-11-04},
	journal = {Journal of Vegetation Science},
	author = {Keddy, Paul A.},
	year = {1992},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.2307/3235676},
	keywords = {Community ecology, Fire, Flooding, Island, Model, Natural selection, Prediction, Species pool, Trait},
	pages = {157--164},
	file = {Snapshot:/Users/leitejard/Zotero/storage/AW2GZ4JY/3235676.html:text/html},
}

