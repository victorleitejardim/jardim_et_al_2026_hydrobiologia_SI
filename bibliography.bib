	year = {2002},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1046/j.1439-0426.2002.00336.x},
	pages = {81--86},
	file = {Full Text:/Users/leitejard/Zotero/storage/6FUR8LFM/Pita et al. - 2002 - Feeding habits of the gilthead seabream (Sparus aurata) from the Ria Formosa (southern Portugal) as.pdf:application/pdf;Snapshot:/Users/leitejard/Zotero/storage/BASPKPU2/j.1439-0426.2002.00336.html:text/html},
}

