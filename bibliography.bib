@article{sabath_expansion_1981,
	title = {Expansion of the {Range} of the {Introduced} {Toad} {Bufo} marinus in {Australia} from 1935 to 1974},
	url = {file:///C:/Users/Victor/Desktop/sabath1981.pdf},
	abstract = {The marine toad, Bufo marinus, was introduced to Australia from Hawaii in 1935. From the initial introduction site (Gordonvale, Queensland), the species was deliberately introduced to Mossman, Babinda, Ingham, Bamaroo, Giru, Ayr, Mackay, Bundaberg and Isis in the coastal Queensland sugar cane districts by 1937. B. marinus dispersed from these areas with the population undergoing an exponential increase in geographical range during the 40 year period from 1935 to 1974. The mode of dispersal was primarily natural or short distance move-ments aided by humans. The species is now found in 584,000 km2 or 33.8\% of Queensland. The geographical growth rate has been 8.1\% per year and expansion continues at all margins of the current range. DURING the past 200 years, associated with the movement of humans, there have been deliberate and accidental introductions of numerous animal and plant species from one part of the world to another. The histories of many of these introductions are documented and have been reviewed by Elton (1958). The marine toad, Bufo marinus (Linnaeus), is by far the most widely and successfully introduced amphibian species, and it has one of the most extensive, documented histories of introduc-tion of any vertebrate. B. marinus occurs naturally in Mexico, Cen-tral and tropical South America, with a natural range extending from approximately 270N lat-itude in southern Texas and north-western Mexico to 100S latitude in central Brazil (Zug and Zug, 1979). Deliberate introductions have extended the range to include islands through-out the Carribean and the Pacific as well as con-tinental Australia and Florida, USA. Honneg-ger (1970) has reviewed the history of introductions. The introduction of 101 individ-uals to Australia took place in 1935 and these were maintained at Gordonvale near Cairns, Queensland. Initially the toads were distributed in the Cairns, Gordonvale, Innisfail and Tully districts, and later (between September 1936 and May 1937) were liberated in Mossman, Ba-binda, Ingham, Bambaroo, Giru, Ayr, Mackay, Bundaberg and Isis districts (Mungomery, 1937). Mungomery (1935, 1936, 1937), acting for the sugar cane industry, dispersed the species throughout the cane growing areas of Queens-land. He emphasized the beneficial attributes of the toad, particularly its potential for pest con-trol. There were, however, many protests to the introduction of B. marinus to Australia from natural history societies and individual natu-ralists (Kinghorn, 1938). Froggatt (1936) warned that the toad could become a serious pest. At present the species is viewed as a minor pest by government officials. It is poisonous and is considered a danger to humans, pets and domesticated fowl. It is believed to compete with native anurans and to poison native pred-ators (marsupial cats, Dasyurus sp.). Covacevich and Archer (1975) reviewed the hypothetical detrimental effects on native vertebrates. State legislation restricts importation of B. marinus to Western Australia, South Australia and the Northern Territory (Tyler, 1975). The present report describes the rate and direction of population spread of B. marinus in Queensland, Australia since its introduction in 1935. The information will be used as a basis for the construction of a predictive model for the future spread and eventual distribution of the species on the Australian continent.},
	number = {3},
	journal = {Copeia},
	author = {Sabath, Michael D and Boughton, Walter C and Easteal, Simon},
	year = {1981},
	keywords = {/unread},
	pages = {676--680},
	file = {Sabath et al_1981_Expansion of the Range of the Introduced Toad Bufo marinus in Australia from.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Sabath et al_1981_Expansion of the Range of the Introduced Toad Bufo marinus in Australia from.pdf:application/pdf},
}

@article{hone_rate_1999,
	title = {On rate of increase (r): patterns of variation in {Australian} mammals and the implications for wildlife management},
	volume = {36},
	url = {file:///C:/Users/Victor/Desktop/ECO VIRTUAL/Hone_-1999-Journal_of_Applied_Ecology.pdf},
	abstract = {1. The annual rate of increase of a wildlife population is the change in abundance or density from one year to the next. This paper compares the expected and observed means and frequency distributions of annual instantaneous rates of increase (r) for unmanipulated ®eld populations of the European rabbit Oryctolagus cuniculus, red fox Vulpes vulpes and house mouse Mus domesticus in Australia. 2. The observed mean r was not signi®cantly dierent from zero, the expected value, for each species, and the observed frequency distributions were not signi®-cantly dierent from the expected normal distributions. 3. The observed distributions were used to estimate the threshold proportions of pests that need to be killed, harvested or sterilized to stop population growth. To stop maximum population growth, as can occur after large population reductions, the proportion to kill, harvest or sterilize ranged from 0´65 year ±1 for foxes to 0´97 year ±1 for house mice. It is recommended that the estimates are tested experi-mentally. 4. The estimated proportions of pests to control were compared with extensive ®eld data detailing attempts to control the pests. Estimated required levels of fox control were often less than observed levels of control. The required levels of rabbit and house mouse control could be higher than observed levels.},
	journal = {Journal of Applied Ecology},
	author = {Hone, Jim},
	year = {1999},
	keywords = {/unread, fertility control, house mouse, Key-words, pest control, rabbit, red fox},
	pages = {709--718},
	file = {Hone_1999_On rate of increase (r).pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Hone_1999_On rate of increase (r).pdf:application/pdf},
}

