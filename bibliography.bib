}

@article{widdicombe_effects_2009,
	title = {Effects of {CO2} induced seawater acidification on infaunal diversity and sediment nutrient fluxes},
	volume = {379},
	issn = {01718630},
	doi = {10.3354/meps07894},
	abstract = {A mesocosm experiment was conducted to quantify the effects of short- (2 wk) and longterm (20 wk) exposure to acidified seawater on the structure and diversity of macrofaunal and nematode assemblages in 2 different sediment types. The impact of acidified seawater on sediment nutrient fluxes was also determined. Using carbon dioxide (CO2) gas, seawater was acidified to pH 7.3 (mimicking ocean acidification), 6.5 or 5.6 (mimicking leakage from a sub-seabed CO2 store site). Control treatments were maintained in natural seawater (pH ̃8.0). Exposure to acidified seawater significantly altered community structure and reduced diversity for both macrofaunal and nematode assemblages. However, the impact on nematodes was less severe than that on macrofauna. While the communities in both sediment types were significantly affected by changes in seawater pH, impacts on sandy sediment fauna were greater than those on muddy sediment fauna. Sandy sediments also showed the greatest effects with respect to nutrient fluxes. In sand, the efflux of nitrite, nitrate and silicate decreased in response to increased acidification while the efflux of ammonium increased. In mud, acidification increased the efflux of ammonium but had no effect on the other nutrients. We conclude that both leakage from carbon storage and ocean acidification could cause significant changes in the structure and diversity of coastal sediment communities. Lowered seawater pH could also affect nutrient cycling directly by altering bacterial communities and indirectly through impacts on the abundance and activity of key bioturbators. © Inter-Research ch 2009.},
	journal = {Marine Ecology Progress Series},
	author = {Widdicombe, S. and Dashfield, S. L. and McNeill, C. L. and Needham, H. R. and Beesley, A. and McEvoy, A. and Øxnevad, S. and Clarke, K. R. and Berge, J. A.},
	year = {2009},
	keywords = {Biodiversity, Ocean acidification, /unread, Carbon storage, Macrofauna, Meiofauna, Nutrient flux},
	pages = {59--75},
	file = {Widdicombe et al_2009_Effects of CO2 induced seawater acidification on infaunal diversity and.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Widdicombe et al_2009_Effects of CO2 induced seawater acidification on infaunal diversity and.pdf:application/pdf},
}

@article{moodley_vertical_2000,
	title = {Vertical distribution of meiofauna in sediments from contrasting sites in the adriatic sea: {Clues} to the role of abiotic versus biotic control},
