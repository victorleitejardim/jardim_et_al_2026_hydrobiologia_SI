	keywords = {/unread},
	pages = {17359},
	file = {Carneiro et al_2022_Interconnected marine habitats form a single continental-scale reef system in.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Carneiro et al_2022_Interconnected marine habitats form a single continental-scale reef system in.pdf:application/pdf},
