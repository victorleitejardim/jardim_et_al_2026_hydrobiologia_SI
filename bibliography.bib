@incollection{necchi_jr_subphylum_2021,
	address = {Cham},
	title = {Subphylum {Cyanidiophytina}, {Class} {Cyanidiophyceae}; {Subphylum} {Proteorhodophytina}, {Classes} {Compsopogonophyceae}, {Porphyridiophyceae}, {Rhodellophyceae}, and {Stylonematophyceae}},
