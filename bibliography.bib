@article{hind_evolutionary_2018,
	title = {Evolutionary reversals in {Bossiella} ({Corallinales}, {Rhodophyta}): first report of a coralline genus with both geniculate and nongeniculate species},
	volume = {54},
	copyright = {© 2018 Phycological Society of America},
	issn = {1529-8817},
	shorttitle = {Evolutionary reversals in {Bossiella} ({Corallinales}, {Rhodophyta})},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/jpy.12788},
	doi = {10.1111/jpy.12788},
	abstract = {This is the first report of a coralline genus with both geniculate (upright fronds with non-calcified joints) and nongeniculate species that has been verified by DNA sequence data. Two nongeniculate (crustose) species of Bossiella are recognized, B. mayae sp. nov. and B. exarticulata sp. nov. DNA sequencing of the lectotype specimen of Pseudolithophyllum whidbeyense revealed that this name had been misapplied and instead belongs to an undescribed coralline species in the Hapalidiales. Phylogenetic analyses of concatenated DNA sequences (psbA, rbcL, COI-5P) indicate that B. mayae and B. exarticulata represent phenotypic reversals from the geniculate character state back to the nongeniculate character state. Secondary loss of genicula has occurred three times in the subfamily Corallinoideae, once to generate the entirely nongeniculate genus Crusticorallina and twice in the now morphologically heterotypic Bossiella. Since phenotypic reversals have occurred several times during the evolution of coralline algae, we speculate about the putative mechanism and adaptive significance of this phenomenon.},
	language = {en},
	number = {6},
	urldate = {2023-10-09},
	journal = {Journal of Phycology},
	author = {Hind, Katharine R. and Gabrielson, Paul W. and Jensen, Cassandra and Martone, Patrick T.},
	year = {2018},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/jpy.12788},
	keywords = {crustose coralline algae, psbA, rbcL, cryptic species, Bossiella exarticulata, Bossiella mayae, COI-5P, Pseudolithophyllum whidbeyense, secondary loss, sequencing type specimens},
	pages = {788--798},
	file = {Hind et al_2018_Evolutionary reversals in Bossiella (Corallinales, Rhodophyta).pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Hind et al_2018_Evolutionary reversals in Bossiella (Corallinales, Rhodophyta).pdf:application/pdf},
}

