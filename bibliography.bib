	keywords = {Respiration, Destructive Event, Growth Rate, High Growth, High Growth Rate},
	pages = {663--669},
}

@article{tatian_feeding_2008,
	title = {Feeding ecology of benthic filter-feeders at {Potter} {Cove}, an {Antarctic} coastal ecosystem},
