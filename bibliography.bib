@article{clare_biological_2022,
	title = {Biological traits of marine benthic invertebrates in {Northwest} {Europe}},
	volume = {9},
	copyright = {2022 Crown},
	issn = {2052-4463},
	url = {https://www.nature.com/articles/s41597-022-01442-y},
	doi = {10.1038/s41597-022-01442-y},
	abstract = {Biological traits analysis (BTA) provides insight into causes and consequences of biodiversity change that cannot be achieved using traditional taxonomic approaches. However, acquiring information on biological traits (i.e., the behavioural, morphological, and reproductive characteristics of taxa) can be extremely time-consuming, especially for large community datasets, thus hindering the successful application of BTA. Here, we present information on ten key biological traits for over a thousand marine benthic invertebrate taxa surveyed in Northwest Europe (mainly the UK shelf). Scores of 0 to 3 are provided to indicate our confidence that taxa exhibit each possible mode of trait expression. The information was acquired over a decade through an extensive appraisal of relevant sources, including peer-reviewed papers, books, online material and, where necessary, professional judgement. These data may be inspected, used, and augmented by fellow researchers, thus assisting in the wider application of BTA in marine benthic ecology.},
	language = {en},
	number = {1},
	urldate = {2022-07-04},
	journal = {Scientific Data},
	publisher = {Nature Publishing Group},
	author = {Clare, David S. and Bolam, Stefan G. and McIlwaine, Paul S. O. and Garcia, Clement and Murray, Joanna M. and Eggleton, Jacqueline D.},
	month = jun,
	year = {2022},
	note = {Number: 1},
	keywords = {Biodiversity, Community ecology, /unread},
	pages = {339},
	file = {Clare et al_2022_Biological traits of marine benthic invertebrates in Northwest Europe.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Clare et al_2022_Biological traits of marine benthic invertebrates in Northwest Europe.pdf:application/pdf;Snapshot:/Users/leitejard/Zotero/storage/EJRR5Q3N/s41597-022-01442-y.html:text/html},
