@article{dos_santos_differential_2008,
	title = {Differential effects of food availability on population growth and fitness of three species of estuarine, bacterial-feeding nematodes},
	volume = {355},
	issn = {00220981},
	doi = {10.1016/j.jembe.2007.11.015},
	abstract = {The significance of bottom-up controls on biological communities has been a long-standing topic of interest in ecology. However, before environmental effects on communities can be properly assessed, a thorough knowledge of the individual species' responses is required. We studied effects of food availability on population development and on different life-history traits in three species of bacterial-feeding nematodes, Diplolaimelloides oschei, Diplolaimelloides meyli (both Monhysteridae) and Pellioditis marina (Rhabditidae), which co-occur on macrophyte detritus in the Westerschelde Estuary (SW Netherlands). The bacteria Escherichia coli was offered in five food-availability treatments corresponding to initial cell densities from 3 × 1010 cells ml- 1 to 3 × 107 cells ml- 1. The three bacterial-feeding nematode species studied here showed differential responses to food availability, which agreed with the general idea that Rhabditidae have extreme colonization abilities under very high food availability, while Monhysteridae tend to have a somewhat slower population development and comparatively lower food requirements. Several life-history traits, including juvenile mortality and development time, did not exhibit a clear food-availability dependence, but bioenergetics-related parameters did. Results on the F1 generation may, however, be affected by strong maternal effects on life-history traits of their progeny. Patterns of food-availability dependence of population increase and size at maturity were similar in P. marina. Both Diplolaimelloides species, however, exhibited a large body size at maturity but a very low population increase at the highest food availability, suggesting a trade-off between biomass and reproduction. Comparison with published data on other nematode species reveals that nematode responses to food availability as well as to other environmental factors are highly species-specific. © 2007 Elsevier B.V. All rights reserved.},
	number = {1},
	journal = {Journal of Experimental Marine Biology and Ecology},
	author = {dos Santos, G. A.P. and Derycke, S. and Fonsêca-Genevois, V. G. and Coelho, L. C.B.B. and Correia, M. T.S. and Moens, T.},
	month = feb,
	year = {2008},
	keywords = {/unread, Marine, Bacterial-feeding nematodes, Bottom-up control, Fitness, Food availability, Population development},
	pages = {27--40},
}

@article{freshwater_phylogenetic_1994,
	title = {Phylogenetic relationships of some {European} {Gelidium} ({Gelidiales}, {Rhodophyta}) species, based on \textit{{rbcL}} nucleotide sequence analysis},
	volume = {33},
	issn = {0031-8884},
	url = {http://www.phycologia.org/doi/abs/10.2216/i0031-8884-33-3-187.1},
	doi = {10.2216/i0031-8884-33-3-187.1},
	abstract = {In the absence of reliable taxonomic characters, species relationships in Gelidiurn (Gelidiales, Rhodophyta) are poorly understood. In order to produce an independent data set for developing phylogenetic hypotheses and consequently a more natural classification of the genus, the methods and primers for sequencing rbeL were developed and used in a study of 37 Gelidiurn species and populations. Sequence data from 24 European and 13 non-European taxa were obtained and analyzed using parsimony methods. All European taxa were resolved in a single major clade except for Gelidiurn pusi//urn (Stackhouse) Le Jolis, which formed a separate clade within the non-European species. Populations initially identified as G. /atifoliurn (Greville) Bornet et Thuret from Aramar, Spain and G. pu/ehe//urn (Turner) Klitzing from Mallorca, Spain were found to be respectively G. attenuaturn (Turner) Bornet in Thuret and what may represent an endemic Mediterranean species. European G. pusi//urn was distinct from taxa representing G. crina/e (Turner) Lamouroux or G. pu/ehe//urn and all taxa assigned this name from other geographic regions.},
	number = {3},
	journal = {Phycologia},
	author = {Freshwater, D. Wilson and Rueness, J.},
	year = {1994},
	note = {ISBN: 0031-8884},
	keywords = {/unread},
	pages = {187--194},
}

