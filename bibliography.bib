@article{lopez-acosta_sponge_2022,
	title = {Sponge contribution to the silicon cycle of a diatom-rich shallow bay},
	volume = {67},
	copyright = {© 2022 The Authors. Limnology and Oceanography published by Wiley Periodicals LLC on behalf of Association for the Sciences of Limnology and Oceanography.},
	issn = {1939-5590},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/lno.12211},
	doi = {10.1002/lno.12211},
	abstract = {In coastal systems, planktonic and benthic silicifiers compete for the pool of dissolved silicon, a nutrient required to make their skeletons. The contribution of planktonic diatoms to the silicon cycle in coastal systems is often well characterized, while that of benthic silicifiers such as sponges has rarely been quantified. Herein, silicon fluxes and stocks are quantified for the sponge fauna in the benthic communities of the Bay of Brest (France). A total of 45 siliceous sponge species living in the Bay account for a silicon standing stock of 1215 tons, while that of diatoms is only 27 tons. The silicon reservoir accumulated as sponge skeletons in the surface sediments of the Bay rises to 1775 tons, while that of diatom skeletons is only 248 tons. These comparatively large stocks of sponge silicon were estimated to cycle two orders of magnitude slower than the diatom stocks. Sponge silicon stocks need years to decades to be renewed, while diatom turnover lasts only days. Although the sponge monitoring over the last 6 yr indicates no major changes of the sponge stocks, our results do not allow us to conclude if the silicon sponge budget of the Bay is at steady state, and potential scenarios are discussed. The findings buttress the idea that sponges and diatoms play contrasting roles in the marine silicon cycle. The budgets of these two major silicon users need to be integrated and their connections revealed, if we aim to improve our understanding of the silicon cycling in coastal ecosystems.},
	language = {en},
	number = {11},
	urldate = {2026-02-03},
	journal = {Limnology and Oceanography},
	author = {López-Acosta, María and Maldonado, Manuel and Grall, Jacques and Ehrhold, Axel and Sitjà, Cèlia and Galobart, Cristina and Pérez, Fiz F. and Leynaert, Aude},
	year = {2022},
	note = {\_eprint: https://aslopubs.onlinelibrary.wiley.com/doi/pdf/10.1002/lno.12211},
	pages = {2431--2447},
	file = {Full Text PDF:/Users/leitejard/Zotero/storage/ZV8MZCJE/López-Acosta et al. - 2022 - Sponge contribution to the silicon cycle of a diatom-rich shallow bay.pdf:application/pdf;Snapshot:/Users/leitejard/Zotero/storage/HBC55QGA/lno.html:text/html},
}

