	pages = {545--552},
	file = {Full Text PDF:/Users/leitejard/Zotero/storage/9U6XY7SF/Chaoui et al. - 2006 - Growth and reproduction of the gilthead seabream Sparus aurata in Mellah lagoon (north-easter.pdf:application/pdf},
}

