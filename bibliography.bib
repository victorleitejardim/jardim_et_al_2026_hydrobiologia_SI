@inproceedings{potin_annual_1990,
	address = {Dordrecht},
	series = {Developments in {Hydrobiology}},
	title = {Annual growth rate of the calcareous red alga {Lithothamnion} corallioides ({Corallinales}, {Rhodophyta}) in the {Bay} of {Brest}, {France}},
	isbn = {978-94-009-2049-1},
	doi = {10.1007/978-94-009-2049-1_37},
	abstract = {Lithothamnion corallioides Crouan et Crouan (Rhodophyta, Corallinales) is the main constituent of the maerl beds of the Bay of Brest (Atlantic coast of western Brittany). Its growth rate was measured monthly in situ during one year. Growth rates were obtained by an adaptation of the buoyant weight technique. The highest daily growth rate was observed in July and reached 0.26\%d-1(S.D. = 0.06), when expressed as the increase of calcium carbonate weight. The average daily growth rate was 0.12\% d-1 (S.D. = 0.04) for a period of 275 days (summer and autumn 1988, winter 1989). Using this preliminary data, the calcium carbonate accretion rate can be estimated provisionally: 876 g m-2 year-1, a rate much lower than that of tropical reef coralline algae, but higher than that of Lithophyllum incrustans, the well known temperate European reef-builder.},
	language = {en},
	booktitle = {Thirteenth {International} {Seaweed} {Symposium}},
	publisher = {Springer Netherlands},
	author = {Potin, P. and Floc’h, J. Y. and Augris, C. and Cabioch, J.},
	editor = {Lindstrom, Sandra C. and Gabrielson, Paul W.},
