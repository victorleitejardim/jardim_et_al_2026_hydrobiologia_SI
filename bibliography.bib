	author = {Pedersen, Eric J. and Miller, David L. and Simpson, Gavin L. and Ross, Noam},
	month = may,
	year = {2019},
	keywords = {/unread},
	pages = {e6876},
	file = {Pedersen et al_2019_Hierarchical generalized additive models in ecology.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Pedersen et al_2019_Hierarchical generalized additive models in ecology.pdf:application/pdf},
