@article{hall-spencer_impact_2006,
	title = {Impact of fish farms on maerl beds in strongly tidal areas},
	volume = {326},
	issn = {0171-8630, 1616-1599},
	url = {https://www.int-res.com/abstracts/meps/v326/p1-9/},
	doi = {10.3354/meps326001},
	abstract = {In Scotland, Atlantic salmon Salmo salar cages are being moved out of areas with slow water movements, to disperse wastes and reduce impacts on benthic communities. This first study of the effects of fish farms on maerl beds (red algal coralline gravels of high conservation importance) demonstrated major impacts on the benthos, even in strongly tidal areas. SCUBA surveys of 3 fish farms located over maerl revealed a build-up of waste organic matter and 10 to 100-fold higher abundances of scavenging fauna (e.g. Necora puber, Pagurus bernhardus) than on 6 reference maerl beds. Visible waste was noted up to 100 m from cage edges, and all 3 farms caused significant reductions in live maerl cover, upon which this habitat depends. Near-cage infaunal samples showed significant reductions in biodiversity, with small Crustacea (ostracods, isopods, tanaids and cumaceans) being particularly impoverished in the vicinity of cages, and significant increases in the abundance of species tolerant of organic enrichment (e.g. Capitella spp. complex, Ophryotrocha hartmanni). Relocation of fish farms to areas with strong currents is unlikely to prevent detrimental effects to the structure and organisation of the benthos, and ‘fallowing’ (whereby sites are left unstocked for a period of time to allow benthic recovery) is inadvisable where slow-growing biogenic habitats such as maerl are concerned, as this may expand the area impacted.},
	language = {en},
	urldate = {2021-05-21},
	journal = {Marine Ecology Progress Series},
	author = {Hall-Spencer, Jason and White, Nicola and Gillespie, Ewan and Gillham, Katie and Foggo, Andy},
	month = nov,
	year = {2006},
	note = {Type: Article},
	keywords = {/unread, Maerl, Benthos, Scotland, Organic enrichment, Salmon farming},
	pages = {1--9},
	file = {Hall-Spencer et al_2006_Impact of fish farms on maerl beds in strongly tidal areas.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Hall-Spencer et al_2006_Impact of fish farms on maerl beds in strongly tidal areas2.pdf:application/pdf;Hall-Spencer et al_2006_Impact of fish farms on maerl beds in strongly tidal areas.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Hall-Spencer et al_2006_Impact of fish farms on maerl beds in strongly tidal areas.pdf:application/pdf;Snapshot:/Users/leitejard/Zotero/storage/7E2QJ3CQ/p1-9.html:text/html},
}

