@article{burdett_exchange_2017,
	title = {Exchange {Dynamics} {Reveal} {Significant} {Accumulation} of {Dimethylated} {Sulfur} by {Mediterranean} {Benthic} {Communities}},
	volume = {4},
	issn = {2296-7745},
	url = {https://www.frontiersin.org/journals/marine-science/articles/10.3389/fmars.2017.00431/full},
	doi = {10.3389/fmars.2017.00431},
	abstract = {{\textless}p{\textgreater}One fifth of Mediterranean waters can be classified as shelf—much higher than the global average. Consequently, the shelf/coastal zone plays a proportionally greater biogeochemical role than in the major oceans, including the support of a wide range of range of endemic or culturally important species and ecosystems. However, despite their known importance in regulating ecosystem function and the marine sulfur cycle, our understanding of the dynamics of dimethylated sulfur compounds such as dimethylsulphide (DMS) and dimethylsulphoniopropionate (DMSP) in Mediterranean benthic habitats is limited. Here, a community-level approach was adopted to quantify DMS and DMSP dynamics in Mediterranean ecosystems including seagrass ({\textless}italic{\textgreater}Posidonia oceanica{\textless}/italic{\textgreater}) meadows, coralligène (an algal carbonate reef found along the Mediterranean shelf) and macroalgal stands. It was found that {\textless}italic{\textgreater}P. oceanica{\textless}/italic{\textgreater} and coralligène are likely to act as significant benthic stocks of DMSP in the coastal/shelf environment. “Hotspots” of water column DMS and DMSP processing were observed where net benthic production was high (e.g., {\textless}italic{\textgreater}P. oceanica{\textless}/italic{\textgreater} meadows), demonstrating that benthic communities are able to modify DMS biogeochemistry in the overlying water column. High variability between, and within, habitat types illustrates the importance of ecosystem structure and light availability in determining benthic DMS and DMSP accumulation, and highlights a previously under-appreciated complexity in benthic dimethylated sulfur dynamics.{\textless}/p{\textgreater}},
	language = {English},
	urldate = {2024-11-06},
	journal = {Frontiers in Marine Science},
	publisher = {Frontiers},
	author = {Burdett, Heidi L.},
	month = dec,
	year = {2017},
	keywords = {ecosystem, macroalgae, seagrass, Crustose coralline algae (CCA), Community, Dimethylsulphide (DMS), Dimethylsulphoniopropionate (DMSP)},
	file = {Full Text PDF:/Users/leitejard/Zotero/storage/HUWZN8AP/Burdett - 2017 - Exchange Dynamics Reveal Significant Accumulation of Dimethylated Sulfur by Mediterranean Benthic Co.pdf:application/pdf},
}

