	editor = {Krupnik, Igor and Aporta, Claudio and Gearheard, Shari and Laidler, Gita J. and Kielsen Holm, Lene},
	year = {2010},
	keywords = {Baffin Island, Franz Boas, Ice and snow terminology, Inuktitut},
	pages = {377--400},
	file = {Krupnik_Müller-Wille_2010_Franz Boas and Inuktitut Terminology for Ice and Snow.pdf:/Users/leitejard/Library/CloudStorage/GoogleDrive-leitejard@univ-brest.fr/My Drive/Zotero/Krupnik_Müller-Wille_2010_Franz Boas and Inuktitut Terminology for Ice and Snow.pdf:application/pdf},
